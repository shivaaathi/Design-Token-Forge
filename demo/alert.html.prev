  <a href="#sec-surface"><span class="sn-num">5</span>Surface Context</a>
  <a href="#sec-slots"><span class="sn-num">6</span>Slots &amp; Anatomy</a>
  <a href="#sec-accent"><span class="sn-num">7</span>Accent Bar</a>
  <a href="#sec-dismiss"><span class="sn-num">8</span>Dismiss</a>
  <a href="#sec-playground"><span class="sn-num">9</span>Context Playground</a>
  <a href="#sec-a11y"><span class="sn-num">10</span>Accessibility</a>
  <a href="#sec-framework"><span class="sn-num">11</span>Use in Framework</a>
</aside>
<div class="page-content">

<header class="demo-header">
  <h1>Alert Explorer <span>— Design Token Forge</span></h1>
  <div class="demo-meta">
    <span class="demo-badge">91 CSS Variables</span>
    <span class="demo-badge">5 Roles</span>
    <span class="demo-badge">3 Sizes</span>
    <span class="demo-badge">4 Variants</span>
    <span class="demo-badge">7 Axes</span>
  </div>
</header>

<!-- ─── GLOBAL CONTROLS ─────────────────────────────────── -->
<nav class="global-controls" aria-label="Global alert preview controls">
  <div class="control-group">
    <label>Role</label>
    <div class="pill-bar" id="roleBar" role="radiogroup" aria-label="Role selector">
      <button class="pill" role="radio" aria-pressed="true" data-ctrl-role="primary" type="button">Primary</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-role="success" type="button">Success</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-role="warning" type="button">Warning</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-role="danger" type="button">Danger</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-role="neutral" type="button">Neutral</button>
    </div>
  </div>
  <div class="control-divider"></div>
  <div class="control-group">
    <label>Variant</label>
    <div class="pill-bar" id="variantBar" role="radiogroup" aria-label="Variant selector">
      <button class="pill" role="radio" aria-pressed="true" data-ctrl-variant="" type="button">Default</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-variant="filled" type="button">Filled</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-variant="outline" type="button">Outline</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-variant="soft" type="button">Soft</button>
    </div>
  </div>
  <div class="control-divider"></div>
  <div class="control-group">
    <label>Size</label>
    <div class="pill-bar" id="sizeBar" role="radiogroup" aria-label="Size selector">
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-size="small" type="button">Small</button>
      <button class="pill" role="radio" aria-pressed="true" data-ctrl-size="base" type="button">Base</button>
      <button class="pill" role="radio" aria-pressed="false" data-ctrl-size="large" type="button">Large</button>
    </div>
  </div>
</nav>

<main class="demo-main">

  <!-- 1. HERO + INSPECTOR -->
  <section class="section" id="sec-hero">
    <div class="section-header"><h2>Hero Preview</h2><span class="section-tag">Live</span></div>
    <p class="section-desc">Live alert reflecting global controls. Inspector shows resolved token → alias → computed value.</p>
    <div class="section-body">
      <div class="hero">
        <div class="hero-preview" id="heroPreview" style="width:100%"></div>
        <div class="hero-inspector" id="heroInspector"><div class="inspector-title">Resolved Tokens</div></div>
      </div>
    </div>
  </section>

  <!-- 2. VARIANT GALLERY -->
  <section class="section" id="sec-variants">
    <div class="section-header"><h2>Variant Gallery</h2><span class="section-tag">Surface</span></div>
    <p class="section-desc">Default (soft tinted bg), Filled (solid role bg), Outline (transparent + role border), Soft (subtle bg). Each shown for all 5 roles.</p>
    <div class="section-body" id="variantGallery"></div>
  </section>

  <!-- 3. DENSITY SCALE -->
  <section class="section" id="sec-density">
    <div class="section-header"><h2>Density Scale</h2><span class="section-tag">Dimension</span></div>
    <p class="section-desc">Small, Base, Large. Padding, gap, font-size, icon, and close button all scale per-size.</p>
    <div class="section-body"><div class="alert-stack" id="densityScale" style="padding:32px"></div></div>
  </section>

  <!-- 4. STATE MATRIX -->
  <section class="section" id="sec-states">
    <div class="section-header"><h2>State Matrix</h2><span class="section-tag">States</span></div>
    <p class="section-desc">Every variant in every interactive state.</p>
    <div class="section-body"><div id="stateMatrix"></div></div>
  </section>

  <!-- 5. SURFACE CONTEXT -->
  <section class="section" id="sec-surface">
    <div class="section-header"><h2>Surface Context</h2><span class="section-tag">Surface</span></div>
    <p class="section-desc">Alerts on three background levels to verify contrast.</p>
    <div class="section-body">
      <div class="surface-strip" id="surfaceStrip"></div>
    </div>
  </section>

  <!-- 6. SLOTS & ANATOMY -->
  <section class="section" id="sec-slots">
    <div class="section-header"><h2>Slots &amp; Anatomy</h2><span class="section-tag">Slots</span></div>
    <p class="section-desc">Accent bar, icon, title, body (with links), close button. All optional.</p>
    <div class="section-body"><div class="alert-stack" id="slotsDemo" style="padding:32px"></div></div>
  </section>

  <!-- ═══ CUSTOM SECTIONS ═══ -->

  <!-- 7. ACCENT BAR -->
  <section class="section" id="sec-accent">
    <div class="section-header"><h2>Accent Bar</h2><span class="section-tag">Shape</span></div>
    <p class="section-desc">Left-border accent bar with rounded cap. Width via <code>--alert-accent-width</code>. Hidden on filled variant.</p>
    <div class="section-body"><div class="alert-stack" id="accentGallery" style="padding:32px"></div></div>
  </section>

  <!-- 8. DISMISS -->
  <section class="section" id="sec-dismiss">
    <div class="section-header"><h2>Dismiss</h2><span class="section-tag">Motion</span></div>
    <p class="section-desc">Click × to dismiss. Alert animates out with opacity + translateY transition.</p>
    <div class="section-body">
      <div class="alert-stack" id="dismissDemo" style="padding:32px"></div>
      <div style="padding:0 32px 16px">
        <button type="button" id="resetDismiss" style="padding:6px 14px;font:inherit;font-size:13px;font-weight:600;border-radius:6px;border:1px solid var(--surface-base-cm-outline);background:var(--surface-base-cn-bg);color:var(--surface-base-ct-default);cursor:pointer">Reset alerts</button>
      </div>
    </div>
  </section>

  <!-- 9. CONTEXT PLAYGROUND -->
  <section class="section" id="sec-playground">
    <div class="section-header"><h2>Context Playground</h2><span class="section-tag">Surface × Role</span></div>
    <p class="section-desc">See how alerts adapt across surface contexts and semantic color roles.</p>
    <div class="section-body">
      <div class="pg-controls">
        <div class="pg-ctrl"><label>Density</label>
          <div class="pill-bar" id="pgDensityBar" role="radiogroup" aria-label="Playground density">
            <button class="pill" role="radio" aria-pressed="false" data-pg-size="small" type="button">small</button>
            <button class="pill" role="radio" aria-pressed="true" data-pg-size="base" type="button">base</button>
            <button class="pill" role="radio" aria-pressed="false" data-pg-size="large" type="button">large</button>
          </div>
        </div>
      </div>
      <div class="pg-cards">
        <div class="pg-card" id="pgCardA">
          <div class="pg-card-head">
            <span class="pg-card-label">Card A</span>
            <div class="pg-ctrl"><label>Surface</label><select data-pg-surface="A"><option value="base" selected>Base</option><option value="bright">Bright</option><option value="deep">Deep</option><option value="accent">Accent</option><option value="dim">Dim</option><option value="container">Container</option><option value="over-container">Over-container</option><option value="float">Float</option></select></div>
            <div class="pg-ctrl"><label>Role</label><select data-pg-role="A"><option value="primary" selected>Primary</option><option value="brand">Brand</option><option value="danger">Danger</option><option value="success">Success</option><option value="warning">Warning</option><option value="info">Info</option></select></div>
          </div>
          <div class="pg-card-body" id="pgBodyA"></div>
        </div>
        <div class="pg-card" id="pgCardB">
          <div class="pg-card-head">
            <span class="pg-card-label">Card B</span>
            <div class="pg-ctrl"><label>Surface</label><select data-pg-surface="B"><option value="base">Base</option><option value="bright">Bright</option><option value="deep" selected>Deep</option><option value="accent">Accent</option><option value="dim">Dim</option><option value="container">Container</option><option value="over-container">Over-container</option><option value="float">Float</option></select></div>
            <div class="pg-ctrl"><label>Role</label><select data-pg-role="B"><option value="primary">Primary</option><option value="brand">Brand</option><option value="danger" selected>Danger</option><option value="success">Success</option><option value="warning">Warning</option><option value="info">Info</option></select></div>
          </div>
          <div class="pg-card-body" id="pgBodyB"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. ACCESSIBILITY -->
  <section class="section" id="sec-a11y">
    <div class="section-header"><h2>Accessibility</h2><span class="section-tag">A11y</span></div>
    <p class="section-desc">ARIA roles, keyboard navigation, forced colors, and reduced motion behavior.</p>
    <div class="section-body">
      <div class="a11y-grid">
        <div class="a11y-card">
          <div class="a11y-card-title">Focus Ring</div>
          <p class="a11y-card-desc">Close button shows <code>:focus-visible</code> keyboard ring. Tab to the alert below and press Enter.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px" id="a11yFocus"></div>
        </div>
        <div class="a11y-card">
          <div class="a11y-card-title">Disabled</div>
          <p class="a11y-card-desc"><code>data-disabled</code> applies reduced opacity. Close button becomes inert.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px" id="a11yDisabled"></div>
        </div>
        <div class="a11y-card">
          <div class="a11y-card-title">Reduced Motion</div>
          <p class="a11y-card-desc">When <code>prefers-reduced-motion: reduce</code> is active, dismiss transition resolves to near-instant (0.01ms).</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px" id="a11yMotion"></div>
        </div>
        <div class="a11y-card">
          <div class="a11y-card-title">Forced Colors</div>
          <p class="a11y-card-desc">High Contrast mode: border falls back to <code>CanvasText</code>. Accent bar uses <code>Highlight</code>.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px" id="a11yHC"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FRAMEWORK -->
  <section class="section" id="sec-framework">
    <div class="section-header"><h2>Use in Your Framework</h2><span class="section-tag">Integration</span></div>
    <p class="section-desc">Wrap this component in your framework. Props become data attributes — our CSS does the rest.</p>
    <div class="section-body">
      <div class="fw-snippet">
        <div class="fw-snippet-head">
          <h3><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg>Alert Wrapper</h3>
          <a class="fw-snippet-link" href="frameworks.html">Full guide <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
        </div>
        <div class="fw-snippet-tabs">
          <button class="fw-snippet-tab" aria-selected="true" data-tab="react" type="button">React</button>
          <button class="fw-snippet-tab" aria-selected="false" data-tab="vue" type="button">Vue</button>
          <button class="fw-snippet-tab" aria-selected="false" data-tab="html" type="button">HTML</button>
          <button class="fw-snippet-tab" aria-selected="false" data-tab="css" type="button">CSS Tokens</button>
        </div>
        <div class="fw-snippet-code" data-panel="react" data-active>&lt;div
  className="alert"
  data-role={role}           {/* primary | success | warning | danger | neutral */}
  data-variant={variant}     {/* filled | outline | soft (omit for default) */}
  data-size={size}           {/* small | base | large */}
  role={['danger','warning'].includes(role) ? 'alert' : 'status'}
&gt;
  {accent &amp;&amp; &lt;span className="alert__accent" /&gt;}
  {icon &amp;&amp; &lt;span className="alert__icon"&gt;{icon}&lt;/span&gt;}
  &lt;div className="alert__content"&gt;
    {title &amp;&amp; &lt;div className="alert__title"&gt;{title}&lt;/div&gt;}
    &lt;div className="alert__body"&gt;{children}&lt;/div&gt;
  &lt;/div&gt;
  {dismissible &amp;&amp; (
    &lt;button className="alert__close" aria-label="Dismiss"
            onClick={onDismiss}&gt;
      &lt;svg viewBox="0 0 24 24"&gt;
        &lt;path d="M18 6L6 18M6 6l12 12" stroke="currentColor" strokeWidth="2"/&gt;
      &lt;/svg&gt;
    &lt;/button&gt;
  )}
&lt;/div&gt;</div>
        <div class="fw-snippet-code" data-panel="vue">&lt;div
  class="alert"
  :data-role="role ?? 'primary'"
  :data-variant="variant || undefined"
  :data-size="size ?? 'base'"
  :role="['danger','warning'].includes(role) ? 'alert' : 'status'"
&gt;
  &lt;span v-if="accent" class="alert__accent" /&gt;
  &lt;span v-if="$slots.icon" class="alert__icon"&gt;&lt;slot name="icon" /&gt;&lt;/span&gt;
  &lt;div class="alert__content"&gt;
    &lt;div v-if="title" class="alert__title"&gt;{{ title }}&lt;/div&gt;
    &lt;div class="alert__body"&gt;&lt;slot /&gt;&lt;/div&gt;
  &lt;/div&gt;
  &lt;button v-if="dismissible" class="alert__close"
          aria-label="Dismiss" @click="$emit('dismiss')"&gt;
    &lt;svg viewBox="0 0 24 24"&gt;
      &lt;path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2"/&gt;
    &lt;/svg&gt;
  &lt;/button&gt;
&lt;/div&gt;</div>
        <div class="fw-snippet-code" data-panel="html">&lt;div class="alert" data-role="primary" data-size="base" role="status"&gt;
  &lt;span class="alert__accent"&gt;&lt;/span&gt;
  &lt;span class="alert__icon"&gt;&lt;svg&gt;…&lt;/svg&gt;&lt;/span&gt;
  &lt;div class="alert__content"&gt;
    &lt;div class="alert__title"&gt;Information&lt;/div&gt;
    &lt;div class="alert__body"&gt;This is a helpful message.&lt;/div&gt;
  &lt;/div&gt;
  &lt;button class="alert__close" aria-label="Dismiss"&gt;
    &lt;svg viewBox="0 0 24 24"&gt;
      &lt;path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2"/&gt;
    &lt;/svg&gt;
  &lt;/button&gt;
&lt;/div&gt;</div>
        <div class="fw-snippet-code" data-panel="css">/* ── Shape ── */
--alert-radius                /* border-radius (default: radius-md) */
--alert-border-width / -style / -color
--alert-accent-width / -radius

/* ── Per-Size (small / base / large) ── */
--alert-padding-y-{size}     /* vertical padding */
--alert-padding-x-{size}     /* horizontal padding */
--alert-gap-{size}            /* main flex gap */
--alert-content-gap-{size}    /* title↔body gap */
--alert-font-size-{size}      /* body font-size */
--alert-title-font-size-{size}
--alert-icon-size-{size}      /* icon dimensions */
--alert-close-size-{size}     /* close button dimensions */

/* ── Surface (per role) ── */
--alert-{role}-bg / -fg / -accent / -border
--alert-{role}-icon-color / -title-color
--alert-{role}-link-color / -link-hover
--alert-{role}-filled-bg / -filled-fg
--alert-{role}-outline-border
--alert-{role}-soft-bg
--alert-shadow

/* ── Typography ── */
--alert-font-family / -font-weight / -line-height
--alert-title-font-weight

/* ── Slots ── */
--alert-close-radius / -opacity / -hover-opacity / -hover-bg

/* ── Motion ── */
--alert-transition-property / -duration / -easing

/* ── State ── */
--alert-disabled-opacity

/* ── A11y ── */
--alert-focus-outline-width / -color</div>
      </div>
    </div>
  </section>

</main>
</div></div>

<!-- ═══════════════ SCRIPTS ═══════════════ -->
<script src="shared.js"></script>
<script src="shared-page.js"></script>
<script>
(function(){
  'use strict';
  var P = window.DTFPage;

  /* ── Constants ─────────────────────────────────────── */
  var ROLES    = ['primary','success','warning','danger','neutral'];
  var SIZES    = ['small','base','large'];
  var VARIANTS = ['','filled','outline','soft'];
  var VLABELS  = {'' :'Default', filled:'Filled', outline:'Outline', soft:'Soft'};

  var ICONS = {
    primary: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>',
    success: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    warning: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>',
    danger:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6"/><path d="M9 9l6 6"/></svg>',
    neutral: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>'
  };
  var CLOSE_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>';
  var TITLES = { primary:'Information', success:'Success', warning:'Warning', danger:'Error', neutral:'Notice' };
  var BODIES = {
    primary: 'This is an informational message to help guide the user.',
    success: 'Your changes have been saved successfully.',
    warning: 'Please review the settings before proceeding.',
    danger:  'Something went wrong. Please try again or contact support.',
    neutral: 'This is a neutral notification for general context.'
  };

  /* ── State ─────────────────────────────────────────── */
  var G = { role:'primary', size:'base', variant:'' };

  /* ── Factory ───────────────────────────────────────── */
  function makeAlert(opts) {
    opts = opts || {};
    var role = opts.role || G.role;
    var el = document.createElement('div');
    el.className = 'alert';
    el.dataset.role = role;
    if (opts.size && opts.size !== 'base') el.dataset.size = opts.size;
    var v = opts.variant !== undefined ? opts.variant : G.variant;
    if (v) el.dataset.variant = v;
    if (opts.disabled) el.dataset.disabled = '';
    if (opts.dismissing) el.dataset.dismissing = '';
    el.setAttribute('role', (role==='danger'||role==='warning') ? 'alert' : 'status');

    if (opts.accent !== false && v !== 'filled') {
      el.appendChild(Object.assign(document.createElement('span'), { className:'alert__accent' }));
    }
    if (opts.icon !== false) {
      var ic = document.createElement('span');
      ic.className = 'alert__icon';
      ic.innerHTML = ICONS[role] || ICONS.primary;
      el.appendChild(ic);
    }
    var content = document.createElement('div');
    content.className = 'alert__content';
    if (opts.title !== false) {
      var t = document.createElement('div');
      t.className = 'alert__title';
      t.textContent = opts.title || TITLES[role];
      content.appendChild(t);
    }
    var b = document.createElement('div');
    b.className = 'alert__body';
    if (opts.bodyHtml) b.innerHTML = opts.bodyHtml;
    else b.textContent = opts.body || BODIES[role];
    content.appendChild(b);
    el.appendChild(content);

    if (opts.dismiss) {
      var btn = document.createElement('button');
      btn.className = 'alert__close';
      btn.setAttribute('aria-label', 'Dismiss');
      btn.type = 'button';
      btn.innerHTML = CLOSE_SVG;
      el.appendChild(btn);
      btn.addEventListener('click', function() {
        el.dataset.dismissing = '';
        setTimeout(function() { el.remove() }, 300);
      });
    }
    return el;
  }

  /* ── Render: Hero ──────────────────────────────────── */
  function renderHero() {
    var el = P.clr('heroPreview');
    el.appendChild(makeAlert({ dismiss:true }));
  }

  /* ── Render: Inspector (3-column via shared helper) ── */
  function updateInspector() {
    var target = document.querySelector('#heroPreview .alert');
    if (!target) return;
    var cs = getComputedStyle(target);
    var s = G.size, r = G.role;
    var rows = [
      ['--alert-radius',                '--radius-md',           cs.borderRadius],
      ['--alert-padding-y-'+s,          '--spacing-14',          cs.paddingTop],
      ['--alert-padding-x-'+s,          '--spacing-16',          cs.paddingLeft],
      ['--alert-gap-'+s,                '--spacing-12',          cs.gap || '—'],
      ['--alert-font-size-'+s,          '--font-size-14',        cs.fontSize],
      ['--alert-icon-size-'+s,          '--spacing-20',          cs.getPropertyValue('--_al-icon-size').trim()||'—'],
      ['--alert-close-size-'+s,         '--spacing-20',          cs.getPropertyValue('--_al-close-size').trim()||'—'],
      ['--alert-'+r+'-bg',             '—',                     cs.backgroundColor],
      ['--alert-'+r+'-fg',             '—',                     cs.color],
      ['--alert-'+r+'-accent',         '--'+r+'-component-bg-default', cs.getPropertyValue('--_al-accent').trim()||'—'],
      ['--alert-accent-width',         '4px',                    cs.getPropertyValue('--_al-accent-w').trim()||'—'],
      ['--alert-transition-duration',  '--duration-normal',      cs.transitionDuration]
    ];
    P.buildInspector('heroInspector', 'Resolved Tokens ('+r+' / '+s+')', rows);
  }

  /* ── Render: Variant Gallery ───────────────────────── */
  function renderVariants() {
    var el = P.clr('variantGallery');
    el.style.padding = '32px';
    VARIANTS.forEach(function(v, vi) {
      var label = document.createElement('div');
      label.className = 'sub-label';
      label.style.padding = '0 0 8px';
      if (vi) label.style.marginTop = '20px';
      label.textContent = VLABELS[v];
      el.appendChild(label);
      var stack = document.createElement('div');
      stack.className = 'alert-stack';
      ROLES.forEach(function(r) {
        stack.appendChild(makeAlert({ role:r, variant:v||undefined }));
      });
      el.appendChild(stack);
    });
  }

  /* ── Render: Density ───────────────────────────────── */
  function renderDensity() {
    var el = P.clr('densityScale');
    SIZES.forEach(function(sz) {
      var lbl = document.createElement('div');
      lbl.className = 'variant-label';
      lbl.textContent = P.cap(sz);
      lbl.style.marginBottom = '4px';
      el.appendChild(lbl);
      el.appendChild(makeAlert({
        size: sz,
        title: P.cap(sz)+' alert',
        body: 'Padding, gap, font, icon, and close all scale with the size token.'
      }));
    });
  }

  /* ── Render: State Matrix (shared helper) ──────────── */
  function renderStates() {
    var vlabels = VARIANTS.map(function(v) { return VLABELS[v]; });
    P.renderStateMatrix('stateMatrix', vlabels,
      ['Default', 'Dismissing', 'Disabled'],
      function(variantLabel, state) {
        var v = '';
        for (var key in VLABELS) { if (VLABELS[key] === variantLabel) v = key; }
        return makeAlert({
          variant: v||undefined,
          disabled: state === 'Disabled',
          dismissing: state === 'Dismissing',
          title: state,
          body: variantLabel + ' variant'
        });
      }
    );
  }

  /* ── Render: Surface Context (shared helper) ───────── */
  function renderSurface() {
    P.renderSurfacePanels('surfaceStrip', function(panel) {
      panel.appendChild(makeAlert({ dismiss:true }));
    });
  }

  /* ── Render: Slots ─────────────────────────────────── */
  function renderSlots() {
    var el = P.clr('slotsDemo');
    var demos = [
      { label:'Full anatomy', opts:{dismiss:true} },
      { label:'Body only (minimal)', opts:{title:false, accent:false, icon:false, body:'Minimal alert — body text only.'} },
      { label:'Title + body', opts:{accent:false, icon:false} },
      { label:'With link in body', opts:{bodyHtml:'Check the <a href="#">documentation</a> for more details.'} },
      { label:'No close button', opts:{body:'Non-dismissible alert. No close button.'} },
      { label:'Icon + body only', opts:{title:false, accent:false} }
    ];
    demos.forEach(function(d) {
      var lbl = document.createElement('div');
      lbl.className = 'variant-label';
      lbl.textContent = d.label;
      el.appendChild(lbl);
      el.appendChild(makeAlert(d.opts));
    });
  }

  /* ── Render: Accent (component-specific) ───────────── */
  function renderAccent() {
    var el = P.clr('accentGallery');
    ROLES.forEach(function(r) {
      el.appendChild(makeAlert({ role:r, title:P.cap(r)+' accent', body:'Left border accent bar with rounded cap.' }));
    });
    var lbl = document.createElement('div');
    lbl.className = 'variant-label';
    lbl.textContent = 'Filled (accent hidden)';
    lbl.style.marginTop = '16px';
    el.appendChild(lbl);
    el.appendChild(makeAlert({ role:'primary', variant:'filled', title:'No accent on filled', body:'Accent bar is hidden when variant="filled" — the bg IS the role color.' }));
  }

  /* ── Render: Dismiss (component-specific) ──────────── */
  function renderDismiss() {
    var el = P.clr('dismissDemo');
    ROLES.forEach(function(r) {
      el.appendChild(makeAlert({ role:r, dismiss:true, title:'Dismissible '+P.cap(r), body:'Click × to dismiss this alert.' }));
    });
  }

  /* ── Render: A11y demos ────────────────────────────── */
  function renderA11y() {
    var f = P.clr('a11yFocus');
    f.appendChild(makeAlert({ dismiss:true, title:'Tab to close button', body:'Focus ring appears on keyboard navigation.' }));
    var d = P.clr('a11yDisabled');
    d.appendChild(makeAlert({ disabled:true }));
    var m = P.clr('a11yMotion');
    m.appendChild(makeAlert({ dismiss:true, body:'Dismiss transition uses prefers-reduced-motion.' }));
    var h = P.clr('a11yHC');
    h.appendChild(makeAlert({ body:'In high-contrast mode, accent bar uses Highlight system color.' }));
  }

  /* ── Playground ────────────────────────────────────── */
  function pgRenderCard(card) {
    var body = document.getElementById('pgBody'+card);
    var surfSel = document.querySelector('[data-pg-surface="'+card+'"]');
    var roleSel = document.querySelector('[data-pg-role="'+card+'"]');
    P.applySurface(body, surfSel.value);
    P.applyRole(body, roleSel.value);
    body.innerHTML = '';
    body.style.display = 'flex';
    body.style.flexDirection = 'column';
    body.style.gap = '12px';
    body.style.padding = '20px';
    var pgSize = 'base';
    var activePill = document.querySelector('#pgDensityBar .pill[aria-pressed="true"]');
    if (activePill) pgSize = activePill.dataset.pgSize;
    VARIANTS.forEach(function(v) {
      var row = document.createElement('div');
      row.className = 'pg-variant-row';
      row.style.flexDirection = 'column';
      row.style.alignItems = 'stretch';
      var lbl = document.createElement('span');
      lbl.className = 'pg-variant-label';
      lbl.textContent = VLABELS[v];
      row.appendChild(lbl);
      row.appendChild(makeAlert({ variant:v||undefined, size:pgSize, dismiss:true }));
      body.appendChild(row);
    });
  }

  /* ── Apply All ─────────────────────────────────────── */
  function applyGlobals() {
    renderHero();
    renderVariants();
    renderDensity();
    renderStates();
    renderSurface();
    renderSlots();
    renderAccent();
    renderDismiss();
    renderA11y();
    requestAnimationFrame(updateInspector);
  }

  /* ── Wire Pill Bars (shared helper) ────────────────── */
  P.wirePillBar('roleBar',    'ctrlRole',    function(v) { G.role=v;    applyGlobals(); });
  P.wirePillBar('variantBar', 'ctrlVariant', function(v) { G.variant=v; applyGlobals(); });
  P.wirePillBar('sizeBar',    'ctrlSize',    function(v) { G.size=v;    applyGlobals(); });

  /* ── Reset dismiss button ──────────────────────────── */
  document.getElementById('resetDismiss').addEventListener('click', function() { renderDismiss(); });

  /* ── Playground wiring ─────────────────────────────── */
  document.querySelectorAll('[data-pg-surface],[data-pg-role]').forEach(function(sel) {
    sel.addEventListener('change', function() {
      var card = this.dataset.pgSurface || this.dataset.pgRole;
      pgRenderCard(card);
    });
  });
  document.getElementById('pgDensityBar').addEventListener('click', function(e) {
    var pill = e.target.closest('.pill');
    if (!pill) return;
    this.querySelectorAll('.pill').forEach(function(p) { p.setAttribute('aria-pressed','false'); });
    pill.setAttribute('aria-pressed','true');
    pgRenderCard('A');
    pgRenderCard('B');
  });

  /* ── Theme hook ────────────────────────────────────── */
  window.DTF.onThemeChange = function() { requestAnimationFrame(updateInspector); };

  /* ── Init ──────────────────────────────────────────── */
  applyGlobals();
  pgRenderCard('A');
  pgRenderCard('B');

})();
</script>
</body>
</html>
