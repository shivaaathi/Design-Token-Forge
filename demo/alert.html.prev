<!-- ═══════════════ PAGE LAYOUT ═══════════════ -->
<div class="page-layout">
<aside class="sidebar-nav" id="sidebarNav" aria-label="Section navigation">
  <a href="#sec-hero"><span class="sn-num">1</span>Hero Preview</a>
  <a href="#sec-variants"><span class="sn-num">2</span>Variant Gallery</a>
  <a href="#sec-density"><span class="sn-num">3</span>Density Scale</a>
