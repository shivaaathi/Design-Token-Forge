{
  "name": "design-token-forge",
  "version": "0.1.0",
  "private": true,
  "description": "A complete design system generator — unified tokens, variable-exhaustive L1 components, multi-product by design.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "echo 'No dev server yet — run package-level scripts'",
    "build": "pnpm -r build",
    "build:packages": "pnpm --filter @design-token-forge/tokens build && pnpm --filter @design-token-forge/components build",
    "build:tokens": "node packages/sync-server/build-static.js",
    "serve:tokens": "node packages/sync-server/server.js",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "audit:gold": "bash scripts/audit-gold-standard.sh",
    "vrt": "npx playwright test --config=playwright.config.js",
    "vrt:update": "npx playwright test --config=playwright.config.js --update-snapshots",
    "vrt:ui": "npx playwright test --config=playwright.config.js --ui",
    "vrt:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1"
  }
}
